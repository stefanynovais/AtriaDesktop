generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------
// Enums
// -----------------------------

enum Role {
  COMUM      // usuário comum (também é a base do "aluno")
  PROFESSOR  // perfil institucional
}

// -----------------------------
// Usuário
// -----------------------------

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(COMUM)
  createdAt DateTime @default(now())

  // Decks importados por este usuário
  decks Deck[]

  // Turmas criadas por este usuário (quando role = PROFESSOR)
  turmasCriadas Turma[] @relation("TurmasDoProfessor")

  // Turmas em que este usuário está inscrito (quando é "aluno")
  turmaMembros TurmaMembro[]

  // Histórico de exercícios realizados
  resultados ResultadoExercicio[]
}

// -----------------------------
// Deck e Flashcards
// -----------------------------

model Deck {
  id        Int      @id @default(autoincrement())
  title     String
  origem    String?  // ex: "Anki", "importação manual", url do deck original
  createdAt DateTime @default(now())

  ownerId Int
  owner   User @relation(fields: [ownerId], references: [id])

  flashcards Flashcard[]
  turmas     TurmaDeck[]
  resultados ResultadoExercicio[]

  // pasta/organização definida pelo usuário (opcional)
  pastaId Int?
  pasta   Pasta? @relation(fields: [pastaId], references: [id])
}

model Flashcard {
  id     Int    @id @default(autoincrement())
  front  String // pergunta / frente do card
  back   String // resposta / verso do card

  deckId Int
  deck   Deck @relation(fields: [deckId], references: [id], onDelete: Cascade)
}

// Pastas para organizar decks por idioma ou outro critério do usuário
model Pasta {
  id     Int    @id @default(autoincrement())
  nome   String
  decks  Deck[]
}

// -----------------------------
// Turmas
// -----------------------------

model Turma {
  id        Int      @id @default(autoincrement())
  nome      String
  codigo    String   @unique // código de acesso gerado automaticamente
  createdAt DateTime @default(now())

  professorId Int
  professor   User @relation("TurmasDoProfessor", fields: [professorId], references: [id])

  membros TurmaMembro[]
  decks   TurmaDeck[]
}

// Relação N:N entre User (alunos) e Turma
model TurmaMembro {
  id       Int      @id @default(autoincrement())
  entrouEm DateTime @default(now())

  turmaId Int
  turma   Turma @relation(fields: [turmaId], references: [id], onDelete: Cascade)

  userId Int
  user   User @relation(fields: [userId], references: [id])

  @@unique([turmaId, userId]) // evita entrar duas vezes na mesma turma
}

// Relação N:N entre Deck e Turma (um deck pode ser usado em várias turmas)
model TurmaDeck {
  id Int @id @default(autoincrement())

  turmaId Int
  turma   Turma @relation(fields: [turmaId], references: [id], onDelete: Cascade)

  deckId Int
  deck   Deck @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@unique([turmaId, deckId])
}

// -----------------------------
// Exercícios / Estatísticas
// -----------------------------

// Cada linha representa uma sessão de exercício feita por um usuário sobre um deck
model ResultadoExercicio {
  id           Int      @id @default(autoincrement())
  totalCards   Int      // quantos cards entraram no exercício
  acertos      Int
  erros        Int
  realizadoEm  DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id])

  deckId Int
  deck   Deck @relation(fields: [deckId], references: [id])
}
