# Porta serial onde o Arduino está conectado.
# Windows: algo tipo COM3, COM4, COM5... (vê no Gerenciador de Dispositivos)
# Mac/Linux: algo tipo /dev/tty.usbmodem14101 ou /dev/ttyUSB0
SERIAL_PORT=COM3

# Velocidade de comunicação (precisa ser igual ao Serial.begin(9600) do Arduino)
BAUD_RATE=9600

# Endereço da sua API rodando localmente
API_URL=http://localhost:4000/api

# Credenciais de um usuário já cadastrado (usadas pra pegar o token automaticamente)
API_EMAIL=professor@teste.com
API_PASSWORD=123456

# Deck usado para gerar as perguntas do quiz físico
DECK_ID=2
